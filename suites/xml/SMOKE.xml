<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="GUI Smoke Suite" parallel="methods" thread-count="2">
    <listeners>
        <listener class-name="org.matbylin.core.listeners.retry.RetryTransformer"/>
    </listeners>
    <test name="GUI SMOKE Tests">
        <groups>
            <run>
                <include name="SMOKE"/>
            </run>
        </groups>
        <packages>
            <package name="org.matbylin.gui.*"/>
        </packages>
    </test>
</suite>